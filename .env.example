# (Linux only) Set to your user ID for Docker file permissions:
# AIRFLOW_UID=1000

# (Optional) Set ONE of these to enable live LLM extraction.
# If none is set, the workshop uses pre-recorded (canned) responses.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...

# (Optional) Override the default Airflow internal secrets (session signing + task auth).
# The defaults in docker-compose.yml are placeholders committed to this public repo, fine for
# this ephemeral, localhost-only workshop stack. Set your own here if you'd rather not share them.
# AIRFLOW_WEBSERVER_SECRET_KEY=
# AIRFLOW_JWT_SECRET=
